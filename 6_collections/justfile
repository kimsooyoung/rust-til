# shellcheck shell=bash
# Chapter 6 — collections. Topics in `src/bin/`; demos in `src/lib.rs`.
# Run: `just run_ex01_tuple_array` … `just run_ex04_iterators`

set shell := ['zsh', '-cu']

default:
    @just --list

run_ex01_tuple_array:
    @cargo run --bin ex01_tuple_array

run_ex02_vec:
    @cargo run --bin ex02_vec

run_ex03_hashmap:
    @cargo run --bin ex03_hashmap

run_ex04_iterators:
    @cargo run --bin ex04_iterators

build-all:
    @cargo build --bins

watch:
    @cargo-watch -qc -x 'run --bin ex01_tuple_array' -x clippy

clippy:
    @cargo clippy
