# shellcheck shell=bash
# Chapter 9 — lifetimes. Topics in `src/bin/`; demos in `src/lib.rs`.
# Run: `just run_ex01_owned_static`, `just run_ex02_random_name`, `just run_ex03_person_elision`

set shell := ['zsh', '-cu']

default:
    @just --list

run_ex01_owned_static:
    @cargo run --bin ex01_owned_static

run_ex02_random_name:
    @cargo run --bin ex02_random_name

run_ex03_person_elision:
    @cargo run --bin ex03_person_elision

build-all:
    @cargo build --bins

watch:
    @cargo-watch -qc -x 'run --bin ex01_owned_static' -x clippy

clippy:
    @cargo clippy
