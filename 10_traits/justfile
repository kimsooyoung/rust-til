# shellcheck shell=bash
# Chapter 10 — traits. Library in `src/lib.rs`; demo in `src/bin/` (no root `main.rs`).
# Run: `just run_1_traits` or `cargo run --bin 1_traits`

set shell := ['zsh', '-cu']

default:
    @just --list

run_1_traits:
    @cargo run --bin 1_traits

build-all:
    @cargo build --bins

watch:
    @cargo-watch -qc -x 'run --bin 1_traits' -x clippy

clippy:
    @cargo clippy
