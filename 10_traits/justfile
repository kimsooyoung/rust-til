# shellcheck shell=bash
# Chapter 10 — traits. Library `src/lib.rs`; demos in `src/bin/`.
# Run: `just run_ex01_person_setup`, `just run_ex02_trait_bounds`

set shell := ['zsh', '-cu']

default:
    @just --list

run_ex01_person_setup:
    @cargo run --bin ex01_person_setup

run_ex02_trait_bounds:
    @cargo run --bin ex02_trait_bounds

build-all:
    @cargo build --bins

watch:
    @cargo-watch -qc -x 'run --bin ex01_person_setup' -x clippy

clippy:
    @cargo clippy
